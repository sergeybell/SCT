INCLUDE 'lattice_sext';

PROCEDURE OPTIMIZE_CHROM SEXTGx1 SEXTGy1 SEXTGx2 SEXTGy2 EBE;
  VARIABLE MU 800; VARIABLE NBAR 800 3;
  VARIABLE OBJ1 1; VARIABLE OBJ2 1; VARIABLE OBJ 1;
                   VARIABLE SGx1 1; VARIABLE SGy1 1;
                   VARIABLE SGx2 1; VARIABLE SGy2 1;
                   VARIABLE EB1 1; VARIABLE EB2 1;
                   VARIABLE E1 1;
                   VARIABLE GAMMA 1;
                   VARIABLE CHROM_X 1; VARIABLE CHROM_Y 1;
  VARIABLE quadKx 1; VARIABLE quadKy 1; VARIABLE quadKz 1; VARIABLE MU0 1;
  VARIABLE MU_TP 800 3;
  WRITE 6 'BEGIN';
  SGx1 := SEXTGx1; SGy1 := SEXTGy1; EB1 := EBE;
  SGx2 := SEXTGx2; SGy2 := SEXTGy2;
  WRITE 6 'EB1 = '&ST(EB1);
  WRITE 6 'SGx1 := '&ST(SGx1)&';'; WRITE 6 'SGy1 := '&ST(SGy1)&';';
  WRITE 6 'SGx2 := '&ST(SGx2)&';'; WRITE 6 'SGy2 := '&ST(SGy2)&';';
  GAMMA := 1.143914;
  FIT SGx2 SGy1 SGx1 ;
    WRITE 6 '====================================';
    LATTICE ABS(SGx1) -ABS(SGy1) ABS(SGx2) -ABS(SGy2) EB1 1;
    TP MU_TP;
    CHROM_X:= (MU_TP(1)|(0&0&0&0&1))*(1+1/GAMMA);
    CHROM_Y:= (MU_TP(2)|(0&0&0&0&1))*(1+1/GAMMA);

    OBJ:= SQRT(SQR(CHROM_X) + SQR(CHROM_Y));

    WRITE 6 'EB1 = '&ST(EB1);
    WRITE 6 'SGx1 := '&ST(SGx1)&';'; WRITE 6 'SGy1 := '&ST(SGy1)&';';
    WRITE 6 'SGx2 := '&ST(SGx2)&';'; WRITE 6 'SGy2 := '&ST(SGy2)&';';
    WRITE 6 'CHROM_X := '&ST(CHROM_X)&';'; WRITE 6 'CHROM_Y := '&ST(CHROM_Y)&';';
    WRITE 6 'OBJ ='&ST(OBJ);
    WRITE 6 '====================================';
  ENDFIT 1E-1 1000 4 OBJ;

    WRITE 6 '====================================';
    WRITE 6 'EB1 = '&ST(EB1);
    WRITE 6 'SGx1 := '&ST(SGx1)&';'; WRITE 6 'SGy1 := '&ST(SGy1)&';';
    WRITE 6 'SGx2 := '&ST(SGx2)&';'; WRITE 6 'SGy2 := '&ST(SGy2)&';';
    WRITE 6 'OBJ ='&ST(OBJ);
    SEXTGx1 := SGx1; SEXTGx2 := SGx2; SEXTGy1 := SGy1;
    WRITE 6 'CHROM_X := '&ST(CHROM_X)&';'; WRITE 6 'CHROM_Y := '&ST(CHROM_Y)&';';
ENDPROCEDURE; {OPTIMIZE}

PROCEDURE MAIN; {optimization} 
    VARIABLE GAMMA 1;
    VARIABLE SGx1 1; VARIABLE SGy1 1; VARIABLE EB1 1;
    VARIABLE SGx2 1; VARIABLE SGy2 1;
    VARIABLE MU 800; VARIABLE NBAR 800 3;
    
    GAMMA := 1.143914;

    OV 3 2 1;
    {DAEPS 1E-12;}
    { SET lattice parameters }
    SET_FOR_DEUTERONS_CHROM GAMMA;
    
    {SEXTUPOLES}
    {natural chromaticity}
    SGx1 := 0.0; SGy1 := 0.0;
    SGX2 := 0.0; SGy2 := 0.0;

    OPTIMIZE_CHROM SGx1 SGy1 SGx2 SGy2 EB1;

    WRITE 6 'EB1 = '&ST(EB1);
    WRITE 6 'SGx1 := '&ST(SGx1)&';'; WRITE 6 'SGy1 := '&ST(SGy1)&';';
    WRITE 6 'SGx2 := '&ST(SGx2)&';'; WRITE 6 'SGy2 := '&ST(SGy2)&';';

ENDPROCEDURE; {MAIN}

PROCEDURE RUN;
  MAIN;
ENDPROCEDURE;
RUN; END;