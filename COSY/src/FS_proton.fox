 DL L_LD ; {LD}
 DL L_LD ; {LD}
 DL L_OD1 ; {OD1}
 DL L_OD2 ; {OD2}
 WIEN2D L_R1 ANG_R1 GAMMA 0 ; {R1}
 DL L_OD2 ; {OD2}
 DL L_BPM ; {BPM}
 DL L_OD1 ; {OD1}
 DL L_LF ; {LF}
 DL L_LFS ; {LFS}
 DL L_OD1 ; {OD1}
 DL L_OD2 ; {OD2}
 DL L_OR1 ; {OR1}
