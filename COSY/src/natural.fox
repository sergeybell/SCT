INCLUDE 'lattice_sext';

PROCEDURE MCMCALC ALPHA0 ALPHA1;
      VARIABLE TMPALPHA 100;
      VARIABLE I 1;
      VARIABLE MCM0 1;
      VARIABLE MCM1 1;
      VARIABLE MCM2 1;
      VARIABLE MCM3 1;
      VARIABLE MCM4 1;

      {L0:=183.4720631502572;}

      MCM MAP SPOS TMPALPHA;
      MCM0 := -TMPALPHA|(0&0&0&0&0&0);
      MCM1 := -TMPALPHA|(0&0&0&0&0&1);
      MCM2 := -2*TMPALPHA|(0&0&0&0&0&2);
      MCM3 := -2*3*TMPALPHA|(0&0&0&0&0&3);
      MCM4 := -2*3*4*TMPALPHA|(0&0&0&0&0&4);

      ALPHA0:= MCM1;
      ALPHA1:= MCM2;

      WRITE 6 '++++++++ MOMENTUM COMPACTION FACTOR ++++++++';
      WRITE 6 'MC0 = '&ST(MCM0);
      WRITE 6 'MC1 = '&ST(MCM1);
      WRITE 6 'MC2 = '&ST(MCM2);
      WRITE 6 'MC3 = '&ST(MCM3);
      WRITE 6 'MC4 = '&ST(MCM4);
      WRITE 6 '++++++++++++++++++++++++++++++++++++++++++++';

ENDPROCEDURE;

PROCEDURE MAIN;
    VARIABLE CHROM_X 1 ; VARIABLE CHROM_Y 1 ;
    VARIABLE SGx1 1 ; VARIABLE SGy1 1 ;
    VARIABLE SGx2 1 ; VARIABLE SGy2 1 ;
    VARIABLE EB1 1 ;  VARIABLE RF 1 ;
    VARIABLE MU 800 ; VARIABLE MU0 1 ; VARIABLE NBAR 800 3 ;
    VARIABLE MU_N_ARR 5000 1000;
    VARIABLE MU_TP 800 3 ;
    VARIABLE quad_Kx 1 ; VARIABLE quad_Ky 1 ; VARIABLE quad_Kz 1 ;
    VARIABLE GAMMA 1 ; VARIABLE BETA 1 ;
    VARIABLE structure 10;
    VARIABLE step_x 1; VARIABLE step_y 1;
    VARIABLE I 1; VARIABLE J 1;  VARIABLE K 1;
    VARIABLE N0 1; VARIABLE N1 1; VARIABLE N2 1;
    VARIABLE ALPHA0 1; VARIABLE ALPHA1 1; VARIABLE ETA1 1;

    structure := 'magnetic';
    RF := 1 ; {RF: 0 - off, 1 - on}
    GAMMA := 1.143914;
    BETA := SQRT(1-1/(GAMMA*GAMMA));

    { 1. Начальные значения секступолей и параметров }
    SGx1 := 0.0 ; SGy1 := 0.0 ; 
    SGx2 := 0.0 ; SGy2 := 0.0 ;
    EB1  := 0.0 ;

    step_x := 0;
    step_y := 0;
    N0 :=  1; N1 := 1; N2 := 1;

    OPENF 3618 'dat/'&structure&'/integrals_0.dat' 'REPLACE'; 
    OPENF 3620 'dat/'&structure&'/particle_spin_tune_0.dat' 'REPLACE'; 
    WRITE 3618 ' SGx1               SGx2              SGy1                SGy2              chrom_x            chrom_y            CONS(MU)           quad_Kx                 quad_Ky                 quad_Kz             alpha_0              alpha_1            eta_1';
    WRITE 3620 ' SGx1               SGx2               SGy1               SGy2               spin_ref          spin_x                  spin_y                  spin_z';
    { --- 2. Начало циклов сканирования --- }
    LOOP K 1 N0 ;
        SGx1 := 0.0;
        LOOP I 1 N1 ;
            SGx2 := 0.0 ;
            PLOOP J 1 N2 ;
                { --- 3. Линейная хроматичность (OV 3 2 1) --- }
                OV 3 2 1 ; 
                SET_FOR_DEUTERONS_CHROM GAMMA ; 
                UM ; LATTICE SGx1 SGy1 SGx2 SGy2 EB1 1 ; 
                TP MU_TP ;
                { Вычисление хроматичности }
                CHROM_X := (MU_TP(1)|(0&0&0&0&1)) * (1+1/GAMMA) ;
                CHROM_Y := (MU_TP(2)|(0&0&0&0&1)) * (1+1/GAMMA) ;
                  
                { --- 4. Спиновая динамика (OV 3 3 0) --- }
                OV 3 3 0 ; 
                SET_FOR_DEUTERONS GAMMA ; { Версия без параметров }
                UM ; LATTICE SGx1 SGy1 SGx2 SGy2 EB1 1 ;
                MCMCALC ALPHA0 ALPHA1;
                TSS MU NBAR 0;
                SR 0 0 0 0 0 0 0 0 1; SSR 0 0 1;
                SR 1*1E-3 0 0 0 0 0 0 0 1; SSR 0 0 1; {X - plane}
                SR 0 0 1*1E-3 0 0 0 0 0 1; SSR 0 0 1; {Y - plane}
                SR 0 0 0 0 0 1*1E-4 0 0 1; SSR 0 0 1; {Z - plane}
                TSS MU NBAR 0;
                GET_TUNE_ENSEMBLE MU_N_ARR;
                
                MU0 := CONS(MU);
                DAPEE MU 11 quad_Kx; DAPEE MU 33 quad_Ky; DAPEE MU 66 quad_Kz;

                ETA1 := ALPHA1+(3/2)*(BETA*BETA)/(GAMMA*GAMMA)-ALPHA0/(GAMMA*GAMMA)+1/(GAMMA*GAMMA*GAMMA*GAMMA);
                WRITE 3618  ST(SGx1)&' '&ST(SGx2)&' '&ST(SGy1)&' '&ST(SGy2)&' '&ST(chrom_x)&' '&ST(chrom_y)&' '&ST(CONS(MU))&' '&ST(quad_Kx)&' '&ST(quad_Ky)&' '&ST(quad_Kz)&' '&ST(ALPHA0)&' '&ST(ALPHA1)&' '&ST(ETA1);
                WRITE 3619  ST(MU_N_ARR(1)|1)&' '&ST(MU_N_ARR(1)|2)&' '&ST(MU_N_ARR(1)|3)&' '&ST(MU_N_ARR(1)|4)&' '&ST(MU_N_ARR(1)|5);
                WRITE 3620  ST(SGx1)&' '&ST(SGx2)&' '&ST(SGy1)&' '&ST(SGy2)&' '&ST(MU_N_ARR(1)|2-CONS(MU))&' '&ST(MU_N_ARR(1)|3-CONS(MU))&' '&ST(MU_N_ARR(1)|4-CONS(MU))&' '&ST(MU_N_ARR(1)|5-CONS(MU));
                
                SGx2 := SGx2 + step_x;
            ENDPLOOP ; { Конец внутреннего цикла SGx1 }
            SGx1 := SGx1 + step_x;
        ENDLOOP ; { Конец внешнего цикла SGx2 }
        SGy1 := SGy1 + step_y;        
    ENDLOOP ; { Конец внешнего цикла SGy1 }
    CLOSEF 3618; CLOSEF 3619; CLOSEF 3620;
    ENDPROCEDURE; {MAIN}
    
    PROCEDURE RUN;
      MAIN;
    ENDPROCEDURE;
RUN; END;
